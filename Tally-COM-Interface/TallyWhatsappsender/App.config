<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      WhatsApp Bridge Configuration

      The DLL no longer hardcodes a base URL. It discovers the running
      service via the registry handshake at HKLM\SOFTWARE\TallyWhatsApp.
      Keep WhatsAppBridgeUrl in case a customer overrides for diagnostics.
    -->
    <add key="WhatsAppBridgeUrl" value=""/>

    <!-- API Configuration -->
    <add key="ApiTimeout" value="30"/>
    <add key="MaxRetries" value="3"/>
    <add key="RetryDelay" value="1000"/>

    <!-- Logging Configuration -->
    <add key="LogFilePath" value="WhatsAppSender.log"/>
    <add key="LogLevel" value="Info"/>
    <add key="EnableConsoleLogging" value="true"/>
    <add key="EnableFileLogging" value="true"/>

    <!-- Message Configuration -->
    <add key="MessageDelay" value="3000"/>
    <add key="ContactValidationLength" value="12"/>

    <!-- File Paths -->
    <add key="MessageTemplatesPath" value="Templates\MessageTemplates.xml"/>
  </appSettings>
</configuration>
